# Discipline Protocol - Environment Variables
# Bu dosyayi .env olarak kopyalayip degerleri doldurun.
# .env dosyasi git'e commit EDILMEZ.

# Offline mod: true ise RPC baglantisi yapilmaz (test icin)
OFFLINE_MODE=true

# Arc Network RPC endpoint
RPC_URL=https://rpc.arc.network

# Deploy edilen kontrat adresi
CONTRACT_ADDRESS=0xYourContractAddressHere

# Validator (AI ajan) private key - ASLA paylasmayin!
PRIVATE_KEY=0xYourPrivateKeyHere

# Ceza adresi (opsiyonel)
PENALTY_ADDRESS=0xYourPenaltyAddressHere
