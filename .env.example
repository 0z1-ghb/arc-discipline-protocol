# Discipline Protocol - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Offline mode: true skips RPC connection (for testing)
OFFLINE_MODE=true

# Arc Network RPC endpoint
RPC_URL=https://rpc.arc.network

# Deployed contract address (Updated after deployment)
CONTRACT_ADDRESS=0xYourContractAddressHere

# USDC Token Address (Arc Testnet: 0x3600...)
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Validator (AI agent) private key - NEVER share!
PRIVATE_KEY=0xYourPrivateKeyHere

# Reward Pool Contract Address (Updated after deployment)
REWARD_POOL_ADDRESS=0xYourRewardPoolAddressHere

# GitHub API Token (Required for rate limits and detailed stats)
# Create at https://github.com/settings/tokens (classic token)
GITHUB_TOKEN=your_github_token_here

# Quality Filter: No minimum line limit (Small bug fixes are allowed)
