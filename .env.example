# Discipline Protocol - Environment Variables
# Bu dosyayi .env olarak kopyalayip degerleri doldurun.
# .env dosyasi git'e commit EDILMEZ.

# Offline mod: true ise RPC baglantisi yapilmaz (test icin)
OFFLINE_MODE=true

# Arc Network RPC endpoint
RPC_URL=https://rpc.arc.network

# Deploy edilen kontrat adresi (Deploy sonrasi guncellenir)
CONTRACT_ADDRESS=0xYourContractAddressHere

# USDC Token Adresi (Arc Testnet: 0x3600...)
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Validator (AI ajan) private key - ASLA paylasmayin!
PRIVATE_KEY=0xYourPrivateKeyHere

# Ceza adresi (opsiyonel)
PENALTY_ADDRESS=0xYourPenaltyAddressHere

# GitHub API Token (Rate limit ve detayli istatistikler icin gerekli)
# https://github.com/settings/tokens adresinden olusturun (classic token)
GITHUB_TOKEN=your_github_token_here

# Kalite Filtresi: Commit satir araligi (Spam korumasi)
MIN_LINES=10
MAX_LINES=30

# Kelime sayisi esigi (Dosya modu icin, GitHub modunda kullanilmaz)
WORD_COUNT_THRESHOLD=100
